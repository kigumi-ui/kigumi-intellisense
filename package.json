{
  "name": "kigumi-intellisense",
  "displayName": "Kigumi IntelliSense",
  "description": "CSS class name and custom property IntelliSense for Web Awesome",
  "Author": "Michael Suzuki",
  "website": "https://kigumi.style",
  "publisher": "kigumi",
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE.md",
  "repository": "https://github.com/Siregar/kigumi-intellisense",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "kigumi",
    "webawesome",
    "intellisense",
    "autocomplete"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:vue",
    "onLanguage:css",
    "onLanguage:scss",
    "onLanguage:less"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Kigumi IntelliSense",
      "properties": {
        "kigumi.classAttributes": {
          "type": "array",
          "default": [
            "class",
            "className"
          ],
          "description": "Attribute names to provide class completions for"
        },
        "kigumi.enable": {
          "type": "boolean",
          "default": true
        }
      }
    }
  },
  "scripts": {
    "generate:utilities": "tsx scripts/parse-utility-classes.ts",
    "generate:tokens": "tsx scripts/parse-css-tokens.ts",
    "generate": "pnpm generate:utilities && pnpm generate:tokens",
    "copy-data": "mkdir -p out/data && cp src/data/*.json out/data/",
    "compile": "tsc -p ./ && pnpm copy-data",
    "watch": "tsc -watch -p ./",
    "package": "pnpm compile && vsce package --no-dependencies",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
